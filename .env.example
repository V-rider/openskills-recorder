# Copy to .env before first run: cp .env.example .env

# SQLite database path (Prisma)
DATABASE_URL="file:./openskills-data/openskills.db"

# Optional: override default artifact directory (~/.openskills)
OPENSKILLS_DATA_DIR=""

# Electron WebSocket port for live recording events
OPENSKILLS_WS_PORT="3847"

# URL loaded by the Electron shell
OPENSKILLS_WEB_URL="http://localhost:3000"
